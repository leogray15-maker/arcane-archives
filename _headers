# Netlify Headers Configuration
# Place this file in your project root as: _headers

# Global headers for all pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# Specific headers for alerts page (TradingView + Firebase)
/alerts.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://www.gstatic.com https://*.firebaseapp.com https://*.googleapis.com https://*.firebaseio.com https://s3.tradingview.com; connect-src 'self' https://www.gstatic.com https://*.firebaseio.com https://*.googleapis.com https://firestore.googleapis.com https://*.cloudfunctions.net https://*.netlify.app https://fcm.googleapis.com wss://*.firebaseio.com https://s3.tradingview.com https://data.tradingview.com wss://*.tradingview.com https://prodata.tradingview.com https://widgetdata.tradingview.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob: https://*.tradingview.com; font-src 'self' data:; frame-src 'self' https://s3.tradingview.com https://s.tradingview.com https://www.tradingview.com; worker-src 'self' blob:; child-src 'self' blob:; media-src 'self' https: blob:;

# Firebase messaging service worker
/firebase-messaging-sw.js
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com; connect-src 'self' https://*.googleapis.com https://fcm.googleapis.com;
  Service-Worker-Allowed: /

# Other pages - standard CSP
