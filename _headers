# Netlify Headers - WORKING VERSION
# Key fix: Added script-src-elem for TradingView script loading

# Alerts page - Allow TradingView + Firebase
/alerts.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.gstatic.com https://*.firebaseapp.com https://*.googleapis.com https://*.firebaseio.com https://s3.tradingview.com https://*.tradingview.com; script-src-elem 'self' 'unsafe-inline' https://*.gstatic.com https://s3.tradingview.com https://*.tradingview.com https://*.firebaseapp.com https://*.googleapis.com; connect-src 'self' https://*.gstatic.com https://*.firebaseio.com https://*.googleapis.com https://firestore.googleapis.com https://*.cloudfunctions.net https://*.netlify.app https://fcm.googleapis.com wss://*.firebaseio.com https://s3.tradingview.com https://*.tradingview.com wss://*.tradingview.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data: https:; frame-src 'self' https://s3.tradingview.com https://*.tradingview.com; worker-src 'self' blob:; child-src 'self' blob:;

# Global headers for all other pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin